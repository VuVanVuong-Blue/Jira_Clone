# Template cho team members - Copy file này thành .env và điền vào giá trị thật
# KHÔNG commit file .env lên GitHub!

# ═══════════════════════════════════════════════
# DATABASE (MySQL)
# ═══════════════════════════════════════════════
DB_URL=jdbc:mysql://localhost:3306/jira_clone?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=

# ═══════════════════════════════════════════════
# JWT SECRET (tối thiểu 64 ký tự)
# ═══════════════════════════════════════════════
JWT_SECRET=your-super-secret-key-at-least-64-characters-long-replace-this-value

# ═══════════════════════════════════════════════
# GOOGLE OAUTH2
# ═══════════════════════════════════════════════
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ═══════════════════════════════════════════════
# BREVO EMAIL API
# ═══════════════════════════════════════════════
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-sender@email.com
BREVO_SENDER_NAME=Jira Clone
